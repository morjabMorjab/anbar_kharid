{
  "name": "anbar-kharid-migration",
  "version": "1.0.0",
  "description": "Migrated from PHP to Node.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server.ts",
    "lint": "tsc --noEmit",
    "build": "esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/server.cjs",
    "start": "node dist/server.cjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "tsx": "^4.15.7",
    "esbuild": "^0.21.5",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/cors": "^2.8.17",
    "typescript": "^5.5.2"
  }
}
